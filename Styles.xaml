<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="BackgroundColor" Color="#f7f7fa"/>
    <SolidColorBrush x:Key="AccentColor" Color="#3cb37a"/>
    <SolidColorBrush x:Key="PaleAccentColor" Color="#a4d5bd"/>

    <!-- General Button -->
    <Style x:Key="GeneralButton"  TargetType="Button">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border BorderBrush="{StaticResource AccentColor}"
                            Background="{StaticResource PaleAccentColor}"
                            CornerRadius="20" Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="1" Opacity="0.5" Color="#a4d5bd"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- 角丸Button -->
    <Style TargetType="Button">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border BorderBrush="{TemplateBinding BorderBrush}" Background="{TemplateBinding Background}" CornerRadius="20" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TextBox -->
    <Style TargetType="TextBox">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border CornerRadius="4" BorderBrush="{StaticResource AccentColor}" BorderThickness="1"
                            Background="{TemplateBinding Background}"
                            VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="1" Color="#a4d5bd"/>
                        </Border.Effect>
                        <ScrollViewer x:Name="PART_ContentHost"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox -->
    <Style TargetType="ComboBox">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Border CornerRadius="4" BorderBrush="{StaticResource AccentColor}" BorderThickness="1" Background="#fff">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="1" Color="#a4d5bd"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Margin="5,0,0,0" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="{StaticResource PaleAccentColor}" CornerRadius="0,3,3,0"/>
                            <ToggleButton Grid.Column="1" Content="▼" BorderThickness="0" Foreground="{StaticResource AccentColor}" Background="transparent"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>