<Window x:Class="Mooforest.Features.IssueManagement.IssueDetailView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Mooforest.Features.IssueManagement"
        mc:Ignorable="d"
        Title="IssueDetailView" Height="720" Width="960" WindowStartupLocation="CenterScreen"
        FontFamily="LINE SEED JP"
        FontSize="14">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <TextBlock Text="{Binding OwnIssue.Title}" FontSize="20" Padding="0,0,0,24" FontWeight="Bold"/>
            <Button Style="{StaticResource Button_Secondary}" HorizontalAlignment="Right"
                    Content="編集"
                    Padding="16,0"
                    Height="36"
                    BorderBrush="{StaticResource BrushGreen800}"
                    Foreground="{StaticResource BrushGreen800}"
                    Click="Close_Click"/>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Content="ステータス" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding OwnIssue.Status}" VerticalAlignment="Center"/>

            <Label Grid.Row="2" Grid.Column="0" Content="説明" FontWeight="Bold" VerticalAlignment="Top"/>
            <ScrollViewer Grid.Row="2" Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding OwnIssue.Description}" TextWrapping="Wrap" VerticalAlignment="Top"/>
            </ScrollViewer>

            <Label Grid.Row="4" Grid.Column="0" Content="次にやること" FontWeight="Bold"/>
            <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding OwnIssue.ToDo}" TextWrapping="Wrap"/>

            <Label Grid.Row="6" Grid.Column="0" Content="作成日" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="6" Grid.Column="2" Text="{Binding OwnIssue.CreatedAt, StringFormat=yyyy-MM-dd}" VerticalAlignment="Center"/>
            <Label Grid.Row="8" Grid.Column="0" Content="更新日" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="8" Grid.Column="2" Text="{Binding OwnIssue.UpdatedAt, StringFormat=yyyy-MM-dd}" VerticalAlignment="Center"/>

        </Grid>
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <TextBlock Text="対応履歴" FontSize="16" Padding="0,16" FontWeight="Bold"/>
                <Button Style="{StaticResource Button_Primary}" HorizontalAlignment="Right"
                    Content="対応履歴を追加する"
                    Padding="16,0"
                    Height="36"
                    Background="{StaticResource BrushGreen800}"
                    Click="Close_Click"/>
            </Grid>
            <DataGrid Grid.Row="1" ItemsSource="{Binding Histories}"
                AutoGenerateColumns="False"
                HeadersVisibility="Column"
                GridLinesVisibility="None"
                RowHeaderWidth="0"
                Background="{StaticResource BrushGray100}"
                BorderThickness="1"
                BorderBrush="{StaticResource BrushGray100}"
                CanUserAddRows="False"
                IsReadOnly="True">

                <!-- なぜか知らないがマウスオーバーや行選択時の背景色をTriggersでうまく制御できないので、色を上書きする-->
                <DataGrid.Resources>
                    <!-- 非アクティブ選択行（ウィンドウが非フォーカス時） -->
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="White"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="{StaticResource Gray800}"/>
                    <!-- アクティブ選択行（フォーカス中） -->
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="White"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{StaticResource Gray800}"/>
                </DataGrid.Resources>

                <!-- ヘッダー -->
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{StaticResource BrushGray50}"/>
                        <Setter Property="Foreground" Value="{StaticResource BrushGray800}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Padding" Value="8, 12"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <!-- 行 -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Padding" Value="0,12"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridRow">
                                    <Border Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}"
                                        BorderThickness="0,1,0,0"
                                        BorderBrush="{StaticResource BrushGray200}">
                                        <DataGridCellsPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="ID" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="12,0">
                                    <TextBlock Text="{Binding Id}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="対応日" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="12,0">
                                    <TextBlock Text="{Binding CreatedAt, StringFormat=yyyy-MM-dd}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="状態" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="12,0">
                                    <TextBlock Text="{Binding Status}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="内容" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="12,0">
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
