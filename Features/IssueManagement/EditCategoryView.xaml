<Window x:Class="Mooforest.Features.IssueManagement.EditCategoryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Mooforest.Features.IssueManagement"
        mc:Ignorable="d"
        Title="カテゴリーを編集する" Height="240" Width="640"
        FontFamily="LINE Seed JP" FontSize="14" WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Row="0" Grid.Column="0">
            <Label Content="カテゴリー" />
            <TextBlock Style="{StaticResource SubText}" Text="コンボボックスが未選択だと新規追加します。"/>
        </StackPanel>
        <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
            <ComboBox x:Name="InputTarget" Width="320"
                        ItemsSource="{x:Static local:IssueManagementModel.Categories}"
                        DisplayMemberPath="Name"
                        SelectedValuePath="Id"/>
            <Button Content="×" Style="{StaticResource ClearButton}" Margin="0,0,8,0" Click="ClearCategory_Click"/>
        </StackPanel>
        <Label Grid.Row="2" Grid.Column="0" Content="新しいカテゴリー名"/>
        <TextBox Grid.Row="2" Grid.Column="2" Style="{StaticResource SingleLineTextBox}" x:Name="InputNewName" Width="320" HorizontalAlignment="Left"/>
        <Button Grid.Row="4" Grid.Column="2" Style="{StaticResource PrimaryButton}"
                HorizontalAlignment="Right"
                Content="カテゴリーを編集する"
                Width="200" Margin="0,0,20,0"
                Click="EditCategory_Click"/>
    </Grid>
</Window>
