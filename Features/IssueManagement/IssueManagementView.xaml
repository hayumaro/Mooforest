<UserControl x:Class="Mooforest.Features.IssueManagement.IssueManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Mooforest.Features.IssueManagement"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             FontFamily="LINE Seed JP" FontSize="14">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Stretch">
                <StackPanel>
                    <Label Content="カテゴリー" Margin="16,0"/>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox x:Name="InputCategory" Margin="16,0,0,0"  Width="120" SelectionChanged="FilterChanged"
                            ItemsSource="{x:Static local:IssueManagementModel.Categories}"
                            DisplayMemberPath="Name"
                            SelectedValuePath="Id"/>
                        <Button Content="×" Style="{StaticResource ClearButton}" Margin="0,0,8,0" Click="ClearCategory_Click"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel>
                    <Label Content="状態" Margin="16,0"/>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox x:Name="InputStatus" Margin="16,0,0,0" Width="120" SelectionChanged="FilterChanged">
                            <ComboBoxItem Content="オープン"/>
                            <ComboBoxItem Content="クローズ"/>
                        </ComboBox>
                        <Button Content="×" Style="{StaticResource ClearButton}" Margin="0,0,8,0" Click="ClearStatus_Click"/>
                    </StackPanel>
                </StackPanel>
                <Button Style="{StaticResource PrimaryButton}" VerticalAlignment="Bottom" HorizontalAlignment="Right" Content="課題を追加する" Padding="16,0" Click="AddIssue_Click"/>
            </StackPanel>
        </Grid>
        <DataGrid Grid.Row="2" ItemsSource="{Binding Issues}" SelectionChanged="DataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="ID" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Padding="12,0">
                                <TextBlock Text="{Binding Id}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="課題名" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource LinkLikeButton}" Tag="{Binding Id}" Content="{Binding Title}" Padding="12,0" Click="Title_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="カテゴリー" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Padding="12,0">
                                <TextBlock Text="{Binding Category}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="状態" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Padding="12,0">
                                <TextBlock Text="{Binding Status}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="作成日" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Padding="12,0">
                                <TextBlock Text="{Binding CreatedAt, StringFormat=yyyy-MM-dd}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="更新日" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Padding="12,0">
                                <TextBlock Text="{Binding UpdatedAt, StringFormat=yyyy-MM-dd}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="親ID" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource LinkLikeButton}" Content="{Binding ParentId}" Padding="12,0" Click="ParentId_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="次にやること" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Padding="12,0">
                                <TextBlock Text="{Binding ToDo}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
