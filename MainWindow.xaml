<Window x:Class="Mooforest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Mooforest"
        mc:Ignorable="d"
        Title="Mooforest" Height="720" Width="1440" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="56"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <ListView x:Name="Menu" SelectionChanged="Menu_SelectionChanged" BorderThickness="0"
                      ItemsSource="{Binding FeatureInfos}"
                      SelectedValuePath="Name">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="MenuBorder"
                                            Background="Transparent"
                                            Padding="0,8,0,8"
                                            BorderThickness="4,0,0,0"
                                            BorderBrush="Transparent">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="MenuBorder" Property="BorderBrush" Value="{StaticResource BrushGray800}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="MenuBorder" Property="Background" Value="{StaticResource BrushGray200}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Image Source="{Binding ImagePath}" Width="40" Height="40"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- 機能画面 -->
        <Border Grid.Column="1" Padding="16">
            <ContentControl x:Name="FeatureView"/>
        </Border>
    </Grid>
</Window>
